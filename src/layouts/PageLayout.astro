---
import "@styles/global.css";
import BaseHead from "@components/BaseHead.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Drawer from "@components/Drawer.astro";
const { title, description, image, pubDate, articleTags } = Astro.props;
import { SITE } from "@consts";
// Analytics/SpeedInsights renderizan custom elements (<vercel-analytics>) que
// son inválidos dentro de <head>: el parser cierra el head prematuramente y
// empuja el stylesheet al <body>, donde cada navegación del ClientRouter lo
// destruye y re-fetchea (causa del FOUC). Por eso viven en el <body>.
import SpeedInsights from "@vercel/speed-insights/astro";
import Analytics from "@vercel/analytics/astro";
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead
      title={`${title} | ${SITE.TITLE}`}
      description={description}
      image={image}
      pubDate={pubDate}
      articleTags={articleTags}
    />
    <slot name="head" />
  </head>
  <body>
    <Header />
    <Drawer />
    <main>
      <slot />
    </main>
    <Footer />
    <Analytics />
    <SpeedInsights />
  </body>
</html>
