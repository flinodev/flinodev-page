---
import PageLayout from "@layouts/PageLayout.astro";
---

<PageLayout title="404 - Página no encontrada" description="La página que buscas no existe">
  <div class="relative bg-white dark:bg-black min-h-screen flex items-center justify-center">
    <div class="mx-auto max-w-screen-sm p-5 text-center space-y-8">
      <!-- Error Code -->
      <div class="animate">
        <h1 class="text-9xl font-bold text-black dark:text-white">404</h1>
      </div>

      <!-- Message -->
      <div class="animate space-y-4">
        <h2 class="text-3xl font-bold text-black dark:text-white">Página no encontrada</h2>
        <p class="text-lg opacity-75">
          Lo sentimos, la página que buscas no existe o ha sido movida.
        </p>
      </div>

      <!-- Actions -->
      <div class="animate flex flex-wrap gap-4 justify-center mt-8">
        <a
          href="/"
          class="py-3 px-6 rounded text-sm lg:text-base bg-black dark:bg-white text-white dark:text-black hover:opacity-75 transition-opacity"
        >
          Volver al inicio
        </a>
        <a
          href="/blog"
          class="py-3 px-6 rounded text-sm lg:text-base border border-black/25 dark:border-white/25 hover:bg-black/5 hover:dark:bg-white/15 transition-colors"
        >
          Ver el blog
        </a>
      </div>

      <!-- Decoration -->
      <div class="animate opacity-50 text-6xl mt-12">🤔</div>
    </div>
  </div>
</PageLayout>
