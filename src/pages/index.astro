---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard";
import StackCard from "@components/StackCard.astro";
import { SITE, SOCIALS } from "@consts";
import TwinklingStars from "@components/TwinklingStars.astro";
import MeteorShower from "@components/MeteorShower.astro";
import EducationCard from "@components/EducationCard.astro";
import { stack } from "@/data/stack";
import { education } from "@/data/education";
import { isWriteup } from "@lib/utils";

const allPosts = (await getCollection("blog")).filter((post) => !post.data.draft);

const posts = allPosts
  .filter((post) => !isWriteup(post))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const writeupsCount = allPosts.filter(isWriteup).length;

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

// Calcular años de experiencia desde primer empleo profesional en desarrollo (Real Metrics - Feb 2019)
const startYear = 2019;
const currentYear = new Date().getFullYear();
const yearsOfExperience = currentYear - startYear;

// Agrupar stack por categoría
const stackByCategory = stack.reduce((acc, item) => {
  const category = item.category || "Otros";
  if (!acc[category]) acc[category] = [];
  acc[category].push(item);
  return acc;
}, {} as Record<string, typeof stack>);
---

<PageLayout title="Francisco Lino — Full Stack Developer" description={SITE.DESCRIPTION}>
  <!-- Light Mode: Particles -->
  <div class="absolute inset-0 block dark:hidden">
    <div id="particles1" class="fixed inset-0"></div>
    <div id="particles2" class="fixed inset-0"></div>
    <div id="particles3" class="fixed inset-0"></div>
  </div>

  <!-- Dark Theme: Stars -->
  <div class="absolute inset-0 bg-black hidden dark:block">
    <div id="stars1" class="fixed inset-0"></div>
    <div id="stars2" class="fixed inset-0"></div>
    <div id="stars3" class="fixed inset-0"></div>
  </div>

  <!-- Dark Theme: Twinkling Stars / Metors -->
  <div id="galaxy" class="fixed inset-0">
    <div class="hidden dark:block">
      <TwinklingStars />
      <MeteorShower />
    </div>
  </div>

  <script is:inline src="/js/bg.js"></script>

  <!-- HERO -->
  <section class="relative h-screen w-full">
    <div id="planetcont" class="animate absolute inset-0 top-1/4 overflow-hidden">
      <div
        id="crescent"
        class="absolute top-0 left-1/2 -translate-x-1/2 w-[250vw] min-h-[100vh] aspect-square rounded-full p-[1px] bg-gradient-to-b from-black/25 dark:from-white/75 from-0% to-transparent to-5%"
      >
        <div
          id="planet"
          class="w-full h-full bg-white dark:bg-black rounded-full p-[1px] overflow-hidden flex justify-center"
        >
          <div
            id="blur"
            class="w-full h-20 rounded-full bg-neutral-900/25 dark:bg-white/25 blur-3xl"
          >
          </div>
        </div>
      </div>
    </div>
    <div class="animate absolute h-full w-full flex items-center justify-center">
      <div class="relative w-full h-full flex items-center justify-center">
        <div class="p-5 text-center space-y-4">
          <div class="animated space-y-1">
            <p class="text-2xl md:text-3xl lg:text-4xl font-bold text-black dark:text-white">
              Francisco Lino
            </p>
            <p class="text-lg md:text-xl font-semibold opacity-75">
              Full Stack Developer • Security
            </p>
          </div>
          <p
            class="animated text-xl md:text-2xl lg:text-3xl font-bold uppercase text-black dark:text-white leading-tight"
          >
            Desarrollo web escalable y seguro
          </p>
          <p class="animated text-sm md:text-base opacity-75">
            Node.js • React • Angular • Golang • PostgreSQL
          </p>
          <div id="ctaButtons" class="animated flex flex-wrap gap-4 justify-center mt-4">
            <a
              href="/projects"
              class="py-2 px-4 rounded truncate text-xs md:text-sm lg:text-base bg-black dark:bg-white text-white dark:text-black hover:opacity-75 blend"
            >
              Ver proyectos
            </a>
            <a
              href="/writeups"
              class="py-2 px-4 truncate rounded text-xs md:text-sm lg:text-base border border-black/25 dark:border-white/25 hover:bg-black/5 hover:dark:bg-white/15 blend"
            >
              Leer writeups
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="relative bg-white dark:bg-black">
    <div class="mx-auto max-w-screen-sm p-5 space-y-24 pb-16">
      <!-- About Section -->
      <section class="animate">
        <div class="space-y-6">
          <!-- Intro personal -->
          <article class="space-y-4">
            <p>
              Soy <b>desarrollador full stack</b> con más de {yearsOfExperience} años de
              experiencia. Actualmente construyo el backend de una aplicación fintech y el sistema
              de cajeros automáticos en Montebit, trabajando con Go, PostgreSQL y Redis.
            </p>
            <p>
              Antes diseñé y migré arquitecturas en Google Cloud para procesar grandes volúmenes de
              datos. Fuera del trabajo estudio seguridad ofensiva —publico writeups de los
              laboratorios que resuelvo— y doy clases de programación.
            </p>
          </article>

          <!-- Métricas visuales -->
          <div class="grid grid-cols-2 gap-4 p-6 bg-black/5 dark:bg-white/5 rounded-lg border border-black/10 dark:border-white/20">
            <div class="text-center">
              <p class="text-3xl font-bold text-black dark:text-white">{yearsOfExperience}+</p>
              <p class="text-sm opacity-75">Años de experiencia</p>
            </div>
            <div class="text-center">
              <p class="text-3xl font-bold text-black dark:text-white">{writeupsCount}</p>
              <p class="text-sm opacity-75">Writeups de seguridad</p>
            </div>
          </div>

          <!-- Especialidades -->
          <div class="space-y-3">
            <h2 class="font-semibold text-black dark:text-white">Especialidades</h2>
            <ul class="list-disc pl-5 space-y-2 opacity-75">
              <li>Desarrollo de APIs REST y microservicios con Node.js y Golang</li>
              <li>Aplicaciones web con React, Angular y Next.js</li>
              <li>Arquitecturas escalables en cloud (GCP, AWS)</li>
              <li>Seguridad web y ethical hacking</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Featured Content Section -->
      <section class="animate">
        <div class="space-y-4">
          <h2 class="font-semibold text-black dark:text-white">Contenido destacado</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <a
              href="/blog/thm/jwt-security"
              class="group p-6 border border-black/10 dark:border-white/20 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 transition-colors duration-300"
            >
              <div class="flex-1">
                <p class="font-semibold text-black dark:text-white group-hover:underline">
                  JWT Security
                </p>
                <p class="text-sm opacity-75 mt-1">
                  Vulnerabilidades comunes en JSON Web Tokens y cómo mitigarlas
                </p>
                <p class="text-xs opacity-50 mt-2">
                  Writeup más leído
                </p>
              </div>
            </a>

            <a
              href="/projects/cognos-tech"
              class="group p-6 border border-black/10 dark:border-white/20 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 transition-colors duration-300"
            >
              <div class="flex-1">
                <p class="font-semibold text-black dark:text-white group-hover:underline">
                  Cognos Tech
                </p>
                <p class="text-sm opacity-75 mt-1">
                  Plataforma educativa para cursos de inglés, construida para un cliente real
                </p>
                <p class="text-xs opacity-50 mt-2">
                  Proyecto destacado
                </p>
              </div>
            </a>
          </div>
        </div>
      </section>

      <!-- Blog Preview Section -->
      <section class="animate">
        <div class="space-y-4">
          <div class="flex justify-between">
            <h2 class="font-semibold text-black dark:text-white">Posts recientes</h2>
            <a
              href="/blog"
              class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend"
            >
              <span
                class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend"
              >
                Todos los posts
              </span>
            </a>
          </div>
          <ul class="space-y-4">
            {
              posts.map((post) => (
                <li>
                  <ArrowCard entry={post} />
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <!-- Tech Stack Section -->
      <section class="animate">
        <div class="space-y-4">
          <h2 class="font-semibold text-black dark:text-white">Stack tecnológico</h2>
          <p>Herramientas con las que trabajo a diario o he usado en proyectos reales:</p>
          <div class="space-y-6 mt-6">
            {
              Object.entries(stackByCategory).map(([category, items]) => (
                <div>
                  <h3 class="text-sm font-semibold text-black dark:text-white mb-3 opacity-75">
                    {category}
                  </h3>
                  <div class="flex flex-wrap items-center gap-2">
                    {items.map((item) => (
                      <StackCard text={item.text} icon={item.icon} href={item.href} />
                    ))}
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <!-- Project Preview Section -->
      <section class="animate">
        <div class="space-y-4">
          <div class="flex justify-between">
            <h2 class="font-semibold text-black dark:text-white">Proyectos recientes</h2>
            <a
              href="/projects"
              class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend"
            >
              <span
                class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend"
              >
                Todos los proyectos
              </span>
            </a>
          </div>
          <ul class="space-y-4">
            {
              projects.map((project) => (
                <li>
                  <ArrowCard entry={project} />
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <section class="animate">
        <div class="space-y-4">
          <h2 class="font-semibold text-black dark:text-white">Educación continua</h2>
          <p>
            La tecnología avanza rápido y mantenerse actualizado es parte del trabajo. Estos son
            mis perfiles en las plataformas donde me capacito continuamente:
          </p>

          <div class="flex justify-center flex-wrap items-center gap-4 mt-5">
            {education.map((item) => <EducationCard icon={item.icon} label={item.label} href={item.href} />)}
          </div>
        </div>
      </section>

      <!-- Contact Section -->
      <section class="animate">
        <div>
          <h2 class="font-semibold text-black dark:text-white">Contáctame</h2>
          <p>¿Tienes un proyecto o una propuesta? Escríbeme por cualquiera de estos medios.</p>
          <div class="grid grid-cols-4 gap-y-2 mt-4 auto-cols-min">
            {
              SOCIALS.map((social) => (
                <>
                  <div class="col-span-1 flex items-center gap-1">
                    <span class="whitespace-nowrap truncate">{social.NAME}</span>
                  </div>
                  <div class="col-span-3 truncate">
                    <a
                      href={social.HREF}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend"
                    >
                      <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                        {social.TEXT}
                      </span>
                    </a>
                  </div>
                </>
              ))
            }
          </div>
        </div>
      </section>
    </div>
  </div>
</PageLayout>
