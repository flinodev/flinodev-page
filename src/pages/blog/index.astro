---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import TopLayout from "@layouts/TopLayout.astro";
import BottomLayout from "@layouts/BottomLayout.astro";
import Blog from "@components/Blog";
import { BLOG } from "@consts";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const tags = [...new Set(posts.flatMap((post) => post.data.tags))].sort((a, b) =>
  a.localeCompare(b)
);

// Calcular estadísticas
const totalPosts = posts.length;
const totalCategories = tags.length;
const currentYear = new Date().getFullYear();
const postsThisYear = posts.filter((post) => post.data.date.getFullYear() === currentYear).length;
---

<PageLayout title={BLOG.TITLE} description={BLOG.DESCRIPTION} image={"/images/blog/main.webp"}>
  <TopLayout>
    <div class="animate page-heading">
      {BLOG.TITLE}
    </div>

    <!-- Estadísticas -->
    <div class="animate grid grid-cols-3 gap-4 mt-8">
      <div class="text-center p-4 bg-black/5 dark:bg-white/5 rounded-lg border border-black/10 dark:border-white/20">
        <p class="text-3xl font-bold text-black dark:text-white">{totalPosts}</p>
        <p class="text-sm opacity-75">Posts publicados</p>
      </div>
      <div class="text-center p-4 bg-black/5 dark:bg-white/5 rounded-lg border border-black/10 dark:border-white/20">
        <p class="text-3xl font-bold text-black dark:text-white">{totalCategories}</p>
        <p class="text-sm opacity-75">Categorías</p>
      </div>
      <div class="text-center p-4 bg-black/5 dark:bg-white/5 rounded-lg border border-black/10 dark:border-white/20">
        <p class="text-3xl font-bold text-black dark:text-white">{postsThisYear}</p>
        <p class="text-sm opacity-75">Posts en {currentYear}</p>
      </div>
    </div>
  </TopLayout>
  <BottomLayout>
    <div class="animate">
      <Blog client:load tags={tags} data={posts} />
    </div>

    <!-- CTA Final -->
    <div class="animate mt-12 p-6 bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/20 rounded-lg text-center">
      <h3 class="text-xl font-bold text-black dark:text-white mb-3">
        💡 ¿Te gusta el contenido?
      </h3>
      <p class="opacity-75 mb-4">
        Sígueme en redes sociales para más tutoriales, tips y contenido sobre desarrollo web y ciberseguridad.
      </p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a
          href="https://www.linkedin.com/in/flinodev/"
          target="_blank"
          rel="noopener noreferrer"
          class="py-2 px-4 rounded text-xs md:text-sm bg-black dark:bg-white text-white dark:text-black hover:opacity-75 transition-opacity duration-200"
        >
          🔗 Sígueme en LinkedIn
        </a>
        <a
          href="https://x.com/flinodev"
          target="_blank"
          rel="noopener noreferrer"
          class="py-2 px-4 rounded text-xs md:text-sm border border-black/25 dark:border-white/25 hover:bg-black/5 dark:hover:bg-white/5 transition-colors duration-200"
        >
          🐦 Sígueme en X
        </a>
      </div>
    </div>
  </BottomLayout>
</PageLayout>
