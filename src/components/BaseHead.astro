---
import SpeedInsights from "@vercel/speed-insights/astro";
import Analytics from "@vercel/analytics/astro";
import { ViewTransitions } from "astro:transitions";
import { SITE } from "@consts";
import { getLangFromUrl, languages, defaultLang } from "@i18n/config";

interface Props {
  title: string;
  description: string;
  image?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const { title, description, image = "/flinodev.webp" } = Astro.props;
const currentLang = getLangFromUrl(Astro.url);

// Construir URLs alternativas para hreflang
const alternateUrls = Object.keys(languages).map((lang) => {
  let path = Astro.url.pathname;

  // Remover prefijo de idioma actual si existe
  Object.keys(languages).forEach((l) => {
    if (path.startsWith(`/${l}/`)) {
      path = path.replace(`/${l}`, "");
    }
  });

  // Agregar prefijo si no es idioma default
  if (lang !== defaultLang) {
    path = `/${lang}${path}`;
  }

  return {
    lang,
    url: new URL(path, Astro.site),
  };
});

// Locale codes para OG tags
const localeMap = {
  es: "es_ES",
  en: "en_US",
  pt: "pt_BR",
};

// Keywords for SEO
const keywords = [
  "Francisco Lino",
  "flinodev",
  "desarrollador full stack",
  "software developer",
  "web development",
  "NodeJS",
  "React",
  "Angular",
  "TypeScript",
  "ciberseguridad",
  "cybersecurity",
  "SQL",
  "TryHackMe",
].join(", ");
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Hreflang tags -->
{alternateUrls.map(({ lang, url }) => (
  <link rel="alternate" hreflang={lang} href={url} />
))}
<link rel="alternate" hreflang="x-default" href={new URL("/", Astro.site)} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content={SITE.AUTHOR} />
<meta name="keywords" content={keywords} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />
<meta property="og:locale" content={localeMap[currentLang]} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.url)} />

<!-- Sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- RSS Feed -->
<link rel="alternate" type="application/rss+xml" title={title} href={`${Astro.site}${currentLang === defaultLang ? "" : currentLang + "/"}rss.xml`} />

<!-- Structured Data (JSON-LD) -->
<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    name: SITE.AUTHOR,
    url: Astro.site,
    inLanguage: currentLang,
    sameAs: [
      "https://github.com/flinodev",
      "https://www.linkedin.com/in/flinodev/",
      "https://x.com/flinodev",
      "https://www.youtube.com/@flinodev",
    ],
    jobTitle: "Full Stack Developer",
    description: SITE.DESCRIPTION,
    knowsAbout: [
      "Web Development",
      "Software Engineering",
      "Cybersecurity",
      "JavaScript",
      "TypeScript",
      "NodeJS",
      "React",
      "Angular",
    ],
  })}
/>

<Analytics />
<SpeedInsights />

<!-- Global Scripts -->
<script defer is:inline src="/js/theme.js"></script>
<script defer is:inline src="/js/scroll.js"></script>
<script defer is:inline src="/js/animate.js"></script>

<ViewTransitions />

<script>
  import type { TransitionBeforeSwapEvent } from "astro:transitions/client";
  document.addEventListener("astro:before-swap", (e) =>
    [
      ...(e as TransitionBeforeSwapEvent).newDocument.head.querySelectorAll('link[as="font"]'),
    ].forEach((link) => link.remove())
  );
</script>
