---
type Props = {
  icon: string;
  label: string;
  href: string;
};

const { icon, label, href } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={label}
  class="w-fit pt-3 px-2 py-2 group rounded border flex gap-2 items-center border-neutral-200 dark:border-neutral-700 hover:bg-neutral-100 hover:dark:bg-neutral-800 blend no-underline"
>
  <svg height={30} aria-hidden="true">
    <use href={`/education.svg#${icon}`}></use>
  </svg>
</a>
