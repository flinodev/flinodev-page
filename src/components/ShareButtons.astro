---
interface Props {
  title: string;
  url?: string;
}

const { title, url } = Astro.props;
const shareUrl = url || Astro.url.href;

// Encode para URLs
const encodedUrl = encodeURIComponent(shareUrl);
const encodedTitle = encodeURIComponent(title);

// URLs de compartir
const twitterUrl = `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}&via=flinodev`;
const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;
---

<div class="mt-12 pt-8 border-t border-black/10 dark:border-white/25">
  <div class="space-y-4">
    <p class="text-sm font-semibold text-black dark:text-white">
      ¿Te resultó útil este contenido?
    </p>
    <p class="text-sm opacity-75">
      Compártelo con otros desarrolladores que puedan encontrarlo interesante
    </p>

    <div class="flex flex-wrap gap-3">
      <!-- Web Share API button -->
      <button
        id="web-share-btn"
        data-title={title}
        data-url={shareUrl}
        class="flex items-center gap-2 py-2 px-4 rounded text-xs md:text-sm bg-black dark:bg-white text-white dark:text-black hover:opacity-75 transition-opacity duration-200"
      >
        <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path>
        </svg>
        <span>Compartir</span>
      </button>

      <!-- Twitter/X -->
      <a
        href={twitterUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 py-2 px-4 rounded text-xs md:text-sm border border-black/25 dark:border-white/25 hover:bg-black/5 dark:hover:bg-white/5 transition-colors duration-200"
      >
        <svg class="size-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
        </svg>
        <span>Twitter</span>
      </a>

      <!-- LinkedIn -->
      <a
        href={linkedinUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 py-2 px-4 rounded text-xs md:text-sm border border-black/25 dark:border-white/25 hover:bg-black/5 dark:hover:bg-white/5 transition-colors duration-200"
      >
        <svg class="size-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
        </svg>
        <span>LinkedIn</span>
      </a>
    </div>

    <!-- Toast notification (hidden by default) -->
    <div
      id="copy-toast"
      class="hidden fixed bottom-4 right-4 bg-black dark:bg-white text-white dark:text-black px-4 py-2 rounded-lg shadow-lg text-sm font-medium z-50"
    >
      ✓ Enlace copiado al portapapeles
    </div>
  </div>
</div>

<script>
  function initShareButtons() {
    const shareBtn = document.getElementById('web-share-btn');
    const toast = document.getElementById('copy-toast');

    if (!shareBtn) return;

    const title = shareBtn.getAttribute('data-title') || '';
    const url = shareBtn.getAttribute('data-url') || window.location.href;

    shareBtn.addEventListener('click', async () => {
      // Try Web Share API first (mobile/modern browsers)
      if (navigator.share) {
        try {
          await navigator.share({
            title: title,
            url: url
          });
        } catch (err) {
          // User cancelled or error - do nothing
          console.log('Share cancelled');
        }
      } else {
        // Fallback: Copy to clipboard
        try {
          await navigator.clipboard.writeText(url);

          // Show toast
          if (toast) {
            toast.classList.remove('hidden');
            setTimeout(() => {
              toast.classList.add('hidden');
            }, 3000);
          }
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      }
    });
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', initShareButtons);

  // Re-initialize after view transitions
  document.addEventListener('astro:after-swap', initShareButtons);
</script>
