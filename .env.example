# Giscus Configuration
# Obtener estos valores de https://giscus.app/ después de configurar GitHub Discussions
# 1. Ve a https://giscus.app/
# 2. Ingresa tu repositorio: flinodev/flinodev-page
# 3. Configura las opciones y copia los valores generados

GISCUS_REPO_ID=R_kgDOxxxxxx
GISCUS_CATEGORY_ID=DIC_kwDOxxxxxx

# Upstash Redis Configuration (para contador de vistas)
# 1. Ve a https://console.upstash.com/
# 2. Crea una cuenta gratuita
# 3. Crea una nueva base de datos Redis
# 4. Copia los valores de "REST API" → ".env"

UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxx
